<script>
function onLoad(){
  document.getElementById('loading').classList.add('gone');
  try{fbq('track','ViewContent',{content_name:'Scheduler Loaded'});}catch(e){}
}

window.addEventListener('message',function(e){
  if(!e.origin||!e.origin.includes('acuityscheduling.com'))return;
  var msg=typeof e.data==='string'?e.data:(e.data&&(e.data.event||e.data.action)||'');
  if(!msg)return;
  if(/date|time|step/i.test(msg)){
    try{fbq('track','InitiateCheckout',{content_name:'Date Selected'});}catch(e){}
    try{__ls('event','booking_date_selected');}catch(e){}
  }
  if(/confirm|scheduled|booked|success/i.test(msg)){
    try{fbq('track','Purchase',{value:850,currency:'USD',content_name:'Session Booked'});}catch(e){}
    try{__ls('event','booking_confirmed');}catch(e){}
    try{va('event',{name:'booking_confirmed'});}catch(e){}
  }
},false);
</script>

