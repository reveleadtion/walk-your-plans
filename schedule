<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --black:#0c0c0c;
  --red:#da3434;
  --white:#fff;
  --serif:'Playfair Display',Georgia,serif;
  --sans:'DM Sans',sans-serif;
}
html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--black);color:var(--white);overflow-x:hidden;-webkit-font-smoothing:antialiased}

nav{display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:60px;border-bottom:1px solid rgba(255,255,255,.07)}
.nl{display:flex;align-items:center;gap:9px;text-decoration:none}
.nav-logo{width:26px;height:26px;object-fit:contain}
.nl-text{font-family:var(--serif);font-size:.92rem;font-weight:900;color:#fff}
.nl-text span{color:var(--red)}
.nav-phone{font-size:.8rem;color:rgba(255,255,255,.4);text-decoration:none;transition:color .2s}
.nav-phone:hover{color:#fff}

header{padding:40px 24px 32px;text-align:center;border-bottom:1px solid rgba(255,255,255,.07)}
.eyebrow{font-size:.62rem;color:var(--red);letter-spacing:.18em;text-transform:uppercase;margin-bottom:12px}
header h1{font-family:var(--serif);font-size:clamp(1.85rem,5.5vw,2.6rem);font-weight:900;line-height:1.1;color:#fff;margin-bottom:10px}
header h1 em{font-style:italic;color:var(--red)}
header p{font-size:.88rem;font-weight:300;color:rgba(255,255,255,.42);line-height:1.7;max-width:320px;margin:0 auto 24px}
.trust-row{display:flex;justify-content:center;gap:18px;flex-wrap:wrap}
.tr-chip{font-size:.7rem;color:rgba(255,255,255,.32);display:flex;align-items:center;gap:5px}
.tr-chip::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--red);flex-shrink:0}

.acuity-wrap{position:relative;background:var(--white)}
.acuity-wrap iframe{display:block;width:100%;height:100vh;min-height:700px;border:none}
.loading{position:absolute;inset:0;background:var(--white);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;transition:opacity .4s,visibility .4s}
.loading.gone{opacity:0;visibility:hidden}
.spin{width:26px;height:26px;border:2.5px solid #e8e8e8;border-top-color:var(--red);border-radius:50%;animation:spin .75s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading p{font-size:.72rem;color:#aaa;letter-spacing:.05em}

footer{padding:24px;border-top:1px solid rgba(255,255,255,.07);text-align:center}
footer p{font-size:.7rem;color:rgba(255,255,255,.2);line-height:1.8}
footer a{color:rgba(255,255,255,.32);text-decoration:none}
footer a:hover{color:var(--red)}
