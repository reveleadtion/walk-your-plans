# ─── Walk Your Plans Detroit — environment variables ────────────────────────
# Copy to .env.local and fill in real values. NEVER commit .env.local.
#
# SECURITY RULES (see .cursor/rules/project.mdc):
#  - Only NEXT_PUBLIC_* vars are exposed to the browser.
#  - The service_role key is SERVER-ONLY. It must never get the NEXT_PUBLIC_
#    prefix and must never be imported into a Client Component.

# Public — safe to expose to the browser (anon key is RLS-protected)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose. Used solely by server code / seed scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site origin used for metadata, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://build.walkyourplansdetroit.com
